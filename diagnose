#!/usr/bin/env bash
# Generate diagnostic info for troubleshooting

cd "$(dirname "$0")"
output_file=diagnose.result

export LANG=C LC_ALL=C
rm -f "$output_file"

if [[ $(whoami) == "root" ]]; then
	echo "Error: Do not run as root"
	exit 1
fi

section() {
	echo ""
	echo "--- $1 ---"
}
cmd() { "$@" 2>&1; }

{
	section "Git repo info"
	cmd git remote get-url origin
	cmd git rev-parse HEAD
	cmd git status
	cmd git submodule status --recursive

	section "Distro info"
	cmd cat /etc/os-release

	section "Environment variables"
	cmd printenv XDG_CACHE_HOME XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME
	cmd printenv ILLOGICAL_IMPULSE_VIRTUAL_ENV

	section "Directories"
	cmd ls -la ~/.local/state/quickshell/.venv 2>/dev/null || echo "Not found"

	section "Versions"
	cmd Hyprland --version 2>/dev/null || echo "Hyprland not found"
	cmd pacman -Q quickshell qt6-base 2>/dev/null || echo "Not found"
	cmd pacman -Q ^illogical-impulse- 2>/dev/null || echo "Not found"
} | tee -a "$output_file"

echo ""
echo "Output saved as: $output_file"

if command -v curl &>/dev/null; then
	read -p "Upload to https://0x0.st? (y/N) " p
	if [[ $p == "y" ]]; then
		curl -F"file=@$output_file" -Fexpires=360 https://0x0.st
	fi
fi
